# Copy to .env and fill in values (never commit .env)

# Groq (OpenAI-compatible API)
GROQ_API_KEY=

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/leetcode_ai_companion

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Google OAuth Web Client ID (Chrome extension + token verification)
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
GOOGLE_CLIENT_ID=

# Public Alfa LeetCode API (override if self-hosting)
ALFA_API_BASE_URL=https://alfa-leetcode-api.onrender.com

# Server
PORT=3001
