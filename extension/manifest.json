{
  "manifest_version": 3,
  "name": "LeetCode AI Extension",
  "version": "1.0",
  "description": "AI-powered LeetCode companion",
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:3001/*",
    "http://localhost:5173/*"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "js": ["content_script.js"]
    },
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["bridge.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetCode AI"
  },
  "web_accessible_resources": [
    {
      "resources": ["widget.html", "widget.js", "widget.css"],
      "matches": ["*://leetcode.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}