{
  "manifest_version": 3,
  "name": "LeetCode AI Companion",
  "version": "2.1.0",
  "description": "AI hints, solutions, and a full dashboard synced with your LeetCode stats.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.leetcode.com/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "action": {
    "default_icon": { "16": "icons/icon16.png" },
    "default_title": "Open LeetCode AI dashboard",
    "default_popup": "popup.html"
  },
  "icons": { "16": "icons/icon16.png" },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://www.leetcode.com/problems/*"
      ],
      "js": ["content_script.js"],
      "css": ["widget.css"],
      "type": "module"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["widget.html", "widget.js"],
      "matches": ["https://leetcode.com/*", "https://www.leetcode.com/*"]
    }
  ]
}
